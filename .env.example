VITE_SITE=Base
VITE_PORT=3000
VITE_BASE_URL=https://api.example.com

# 联调开关：设为 http://localhost:3001 走真实后端；不设或空则用 app.config.api_url
# MSW：app.config.enableMsw=true 时 Mock 拦截，VITE_API_BASE_URL 可覆盖
VITE_API_BASE_URL=

# Dev proxy: set when connecting to local backend, e.g. http://localhost:8080
# VITE_PROXY_TARGET=http://localhost:8080

# Analytics (optional)
# VITE_MATOMO_SITE_ID=1
# VITE_MATOMO_URL=https://example.com/matomo.js
# VITE_GROWTHBOOK_API_HOST=https://cdn.growthbook.io
# VITE_GROWTHBOOK_CLIENT_KEY=sdk-xxx
